{
  "manifest_version": 3,
  "name": "PwGuard - 비밀번호 보안 분석기",
  "version": "1.1.0",
  "description": "로그인·회원가입 페이지에서 비밀번호 강도를 실시간 분석하고 재사용을 탐지합니다.",

  "permissions": ["storage", "activeTab"],
  "host_permissions": ["<all_urls>", "http://*.supabase.co/"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],

  "action": {
    "default_popup": "popup.html"
  }
}
